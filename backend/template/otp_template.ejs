<!-- otp_template.ejs -->
<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Email Verification</title>
        <style type="text/css">
            body,
            html {
                margin: 0;
                padding: 0;
                -webkit-text-size-adjust: 100%;
                -ms-text-size-adjust: 100%;
                width: 100%;
                height: 100%;
            }
            table {
                border-spacing: 0;
                border-collapse: collapse;
            }
            td {
                padding: 0;
            }
            img {
                -ms-interpolation-mode: bicubic;
                border: 0;
                height: auto;
                line-height: 100%;
                outline: none;
                text-decoration: none;
            }
            a {
                text-decoration: none;
            }
            .full-width-image {
                width: 100% !important;
                height: auto !important;
            }
            .email-wrapper {
                width: 100%;
                background-color: #f4f4f4;
                padding: 20px 0;
            }
            .email-container {
                max-width: 600px;
                margin: 0 auto;
                background-color: #ffffff;
                border-radius: 1rem;
                border: 1px solid #d1d5db;
                overflow: hidden;
                box-shadow: 0 4px 8px rgba(0, 0, 0, 0.05);
            }

            .header-section {
                height: 150px;
                background-color: #365cce;
                color: #fff;
                text-align: center;
                padding: 20px;
                box-sizing: border-box;
            }
            .header-title {
                font-size: 24px;
                font-weight: bold;
                text-transform: capitalize;
                margin-top: 1rem;
                line-height: 1.2;
            }
            .main-content {
                padding: 24px;
            }
            .otp-box-container {
                text-align: center;
                padding: 16px 0;
            }
            .otp-box {
                border: 1px solid #365cce;
                border-radius: 0.25rem;
                width: 40px;
                height: 40px;
                font-size: 20px;
                font-weight: bold;
                color: #365cce;
                background-color: #e6f2ff;
                text-align: center;
                vertical-align: middle;
                line-height: 40px;
                margin: 0;
            }
            .otp-gap {
                width: 20px;
            }
            .footer-section {
                background-color: #365cce;
                padding: 10px 20px;
                color: #fff;
                text-align: center;
                font-size: 14px;
            }
            .footer-link {
                color: #eff8ff;
                font-weight: 600;
                text-decoration: none;
            }
            p {
                margin: 0 0 10px 0;
                line-height: 1.5;
                color: #4b5563;
            }
            h4 {
                margin: 0 0 10px 0;
                color: #374151;
            }
            .mt-1 {
                margin-top: 1rem;
            }
            .mt-2 {
                margin-top: 2rem;
            }
            .mb-0 {
                margin-bottom: 0;
            }
        </style>
    </head>
    <body style="margin: 0; padding: 0; width: 100%; background-color: #f4f4f4" bgcolor="#f4f4f4">
        <table
            role="presentation"
            class="email-wrapper"
            align="center"
            border="0"
            cellpadding="0"
            cellspacing="0"
            width="100%"
        >
            <tr>
                <td align="center" valign="top" style="padding: 20px 0" bgcolor="#f4f4f4">
                    <table
                        role="presentation"
                        class="email-container"
                        align="center"
                        border="0"
                        cellpadding="0"
                        cellspacing="0"
                        width="100%"
                    >
                        <tr>
                            <td class="header-section" valign="middle">
                                <!-- Header content -->
                                <table
                                    role="presentation"
                                    border="0"
                                    cellpadding="0"
                                    cellspacing="0"
                                    width="100%"
                                >
                                    <tr>
                                        <td align="center">
                                            <table
                                                role="presentation"
                                                border="0"
                                                cellpadding="0"
                                                cellspacing="0"
                                            >
                                                <tr>
                                                    <td
                                                        style="
                                                            width: 40px;
                                                            height: 1px;
                                                            background-color: #fff;
                                                        "
                                                    ></td>
                                                    <td
                                                        style="
                                                            padding: 0 10px;
                                                            font-size: 20px;
                                                            color: #fff;
                                                        "
                                                    >
                                                        &#x2709;
                                                    </td>
                                                    <td
                                                        style="
                                                            width: 40px;
                                                            height: 1px;
                                                            background-color: #fff;
                                                        "
                                                    ></td>
                                                </tr>
                                            </table>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td align="center">
                                            <p
                                                class="header-title"
                                                style="color: #fff; margin-top: 1rem"
                                            >
                                                Verify your E-mail Address
                                            </p>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                        <tr>
                            <td class="main-content">
                                <h4 style="color: #374151; margin-bottom: 1rem">Hello,</h4>

                                <p style="line-height: 1.5; color: #4b5563; margin-bottom: 1rem">
                                    Please use the following One Time Password (OTP)
                                </p>
                                <table
                                    role="presentation"
                                    border="0"
                                    cellpadding="0"
                                    cellspacing="0"
                                    align="center"
                                    class="otp-box-container"
                                >
                                    <tr>
                                        <% if (otp) { %> <%
                                        String(otp).split('').forEach(function(digit, index) { %>
                                        <td
                                            class="otp-box"
                                            style="
                                                border: 1px solid #365cce;
                                                border-radius: 0.25rem;
                                                width: 40px;
                                                height: 40px;
                                                font-size: 20px;
                                                font-weight: bold;
                                                color: #365cce;
                                                background-color: #e6f2ff;
                                                text-align: center;
                                                vertical-align: middle;
                                                line-height: 40px; /* Important for vertical centering */
                                            "
                                        >
                                            <%= digit %>
                                        </td>
                                        <% if (index < String(otp).length - 1) { %>
                                        <td class="otp-gap" style="width: 20px"></td>
                                        <!-- Gap cell -->
                                        <% } %> <% }); %> <% } else { %>
                                        <td style="text-align: center; padding: 10px">
                                            No OTP provided.
                                        </td>
                                        <% } %>
                                    </tr>
                                </table>

                                <p class="mt-1" style="line-height: 1.75; color: #4b5563">
                                    This passcode will only be valid for the next
                                    <span style="font-weight: bold"> 5 minutes</span>.
                                </p>

                                <p class="mt-2 mb-0" style="color: #4b5563; text-align: right">
                                    Thank you
                                </p>
                            </td>
                        </tr>
                        <tr>
                            <td class="footer-section">
                                <!-- Footer content -->
                                <p style="color: #fff; margin: 0">
                                    &copy; 2025
                                    <a
                                        class="footer-link"
                                        href="https://www.gbtsolutions.in/"
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        style="
                                            color: #eff8ff;
                                            font-weight: 600;
                                            text-decoration: none;
                                        "
                                        >GBT Tech Solutions</a
                                    >. All Rights Reserved.
                                </p>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </body>
</html>
