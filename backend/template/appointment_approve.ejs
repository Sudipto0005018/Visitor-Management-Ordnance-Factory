<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Appointment Approved!</title>
        <style type="text/css">
            body,
            html {
                margin: 0;
                padding: 0;
                -webkit-text-size-adjust: 100%;
                -ms-text-size-adjust: 100%;
                width: 100%;
                height: 100%;
            }
            table {
                border-spacing: 0;
                border-collapse: collapse;
            }
            td {
                padding: 0;
            }
            img {
                -ms-interpolation-mode: bicubic;
                border: 0;
                height: auto;
                line-height: 100%;
                outline: none;
                text-decoration: none;
            }
            a {
                text-decoration: none;
            }
            .full-width-image {
                width: 100% !important;
                height: auto !important;
            }
            .email-wrapper {
                width: 100%;
                background-color: #f4f4f4;
                padding: 20px 0;
            }
            .email-container {
                max-width: 600px;
                margin: 0 auto;
                background-color: #ffffff;
                border-radius: 1rem;
                border: 1px solid #d1d5db;
                overflow: hidden;
                box-shadow: 0 4px 8px rgba(0, 0, 0, 0.05);
            }

            .header-section {
                height: 150px;
                background-color: #365cce;
                color: #fff;
                text-align: center;
                padding: 20px;
                box-sizing: border-box;
            }
            .header-title {
                font-size: 24px;
                font-weight: bold;
                text-transform: capitalize;
                margin-top: 1rem;
                line-height: 1.2;
            }
            .main-content {
                padding: 24px;
            }
            .detail-row {
                padding: 8px 0;
            }
            .detail-label {
                font-weight: bold;
                color: #374151;
                width: 30%;
                vertical-align: top;
            }
            .detail-value {
                color: #4b5563;
                width: 70%;
            }
            .footer-section {
                background-color: #365cce;
                padding: 10px 20px;
                color: #fff;
                text-align: center;
                font-size: 14px;
            }
            .footer-link {
                color: #e6f7ff;
                font-weight: 600;
                text-decoration: none;
            }
            p {
                margin: 0 0 10px 0;
                line-height: 1.5;
                color: #4b5563;
            }
            h4 {
                margin: 0 0 10px 0;
                color: #374151;
            }
            .mt-1 {
                margin-top: 1rem;
            }
            .mt-2 {
                margin-top: 2rem;
            }
            .mb-0 {
                margin-bottom: 0;
            }
        </style>
    </head>
    <body style="margin: 0; padding: 0; width: 100%; background-color: #f4f4f4" bgcolor="#f4f4f4">
        <table
            role="presentation"
            class="email-wrapper"
            align="center"
            border="0"
            cellpadding="0"
            cellspacing="0"
            width="100%"
        >
            <tr>
                <td align="center" valign="top" style="padding: 20px 0" bgcolor="#f4f4f4">
                    <table
                        role="presentation"
                        class="email-container"
                        align="center"
                        border="0"
                        cellpadding="0"
                        cellspacing="0"
                        width="100%"
                    >
                        <tr>
                            <td class="header-section" valign="middle">
                                <table
                                    role="presentation"
                                    border="0"
                                    cellpadding="0"
                                    cellspacing="0"
                                    width="100%"
                                >
                                    <tr>
                                        <td align="center">
                                            <table
                                                role="presentation"
                                                border="0"
                                                cellpadding="0"
                                                cellspacing="0"
                                            >
                                                <tr>
                                                    <td
                                                        style="
                                                            width: 40px;
                                                            height: 1px;
                                                            background-color: #fff;
                                                        "
                                                    ></td>
                                                    <td
                                                        style="
                                                            padding: 0 10px;
                                                            font-size: 20px;
                                                            color: #fff;
                                                        "
                                                    >
                                                        &#x2705;
                                                    </td>
                                                    <td
                                                        style="
                                                            width: 40px;
                                                            height: 1px;
                                                            background-color: #fff;
                                                        "
                                                    ></td>
                                                </tr>
                                            </table>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td align="center">
                                            <p
                                                class="header-title"
                                                style="color: #fff; margin-top: 1rem"
                                            >
                                                Your Appointment is Approved!
                                            </p>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                        <tr>
                            <td class="main-content">
                                <h4 style="color: #374151; margin-bottom: 1rem">
                                    Hello <%= name %>,
                                </h4>

                                <p style="line-height: 1.5; color: #4b5563; margin-bottom: 1rem">
                                    We're pleased to inform you that your appointment has been
                                    successfully approved.
                                </p>

                                <table
                                    role="presentation"
                                    border="0"
                                    cellpadding="0"
                                    cellspacing="0"
                                    width="100%"
                                    style="margin-top: 1rem; border-collapse: collapse"
                                >
                                    <tr>
                                        <td class="detail-label" style="padding-right: 10px">
                                            Ref No:
                                        </td>
                                        <td class="detail-value"><%= refNumber %></td>
                                    </tr>
                                    <tr>
                                        <td class="detail-label" style="padding-right: 10px">
                                            Date:
                                        </td>
                                        <td class="detail-value"><%= date %></td>
                                    </tr>
                                    <tr>
                                        <td class="detail-label" style="padding-right: 10px">
                                            Time:
                                        </td>
                                        <td class="detail-value"><%= time %></td>
                                    </tr>
                                </table>

                                <p class="mt-2 mb-0" style="color: #4b5563; text-align: right">
                                    Thank you, <br />
                                    GBT Tech Team
                                </p>
                            </td>
                        </tr>
                        <tr>
                            <td class="footer-section">
                                <p style="color: #fff; margin: 0">
                                    &copy; 2025
                                    <a
                                        class="footer-link"
                                        href="https://www.gbtsolutions.in/"
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        style="
                                            color: #e6ffe6;
                                            font-weight: 600;
                                            text-decoration: none;
                                        "
                                        >GBT Tech Solutions</a
                                    >. All Rights Reserved.
                                </p>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </body>
</html>
